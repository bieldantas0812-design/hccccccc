{
  "manifest_version": 3,
  "name": "Prompt Vault",
  "version": "1.0.0",
  "description": "Central de gerenciamento de prompts para produtividade com IA.",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
